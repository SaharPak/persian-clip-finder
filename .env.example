# Copy this file to .env and fill in the keys you plan to use.
# .env is loaded via python-dotenv. The same values can also be set in
# config.yaml (see config.yaml in the repo root), or passed as CLI flags
# to `python -m persian_clip_finder`.

# For Claude (Anthropic) highlight detection
ANTHROPIC_API_KEY=

# For GPT-4o (OpenAI) highlight detection
OPENAI_API_KEY=

# Optional overrides
# WHISPER_MODEL=large-v3
# WHISPER_DEVICE=auto        # auto | cpu | cuda
# WHISPER_COMPUTE_TYPE=auto  # auto | int8 | float16 | float32
# CLAUDE_MODEL=claude-sonnet-4-6
# GPT_MODEL=gpt-4o
